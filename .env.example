# --- Application ---
APP_NAME=NexCall AI
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
SECRET_KEY=changez-cette-cle-secrete-min-32-caracteres

# --- Base de donnees ---
DATABASE_URL=sqlite+aiosqlite:///./data/nexcall.db

# --- Ringover ---
RINGOVER_API_KEY=votre_cle_api_ringover
