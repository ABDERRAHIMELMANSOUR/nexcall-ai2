# ================================================================
#  NexCall AI v2.0 — Variables d'environnement
#  En local  : cp .env.example .env puis remplir les valeurs
#  Sur Render : configurer dans Dashboard > Environment
# ================================================================

# --- Application ---
APP_NAME=NexCall AI
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
SECRET_KEY=changez-cette-cle-en-production-minimum-32-chars

# --- Base de données (SQLite par défaut) ---
# DATABASE_URL=sqlite+aiosqlite:///./data/nexcall.db

# --- Ringover ---
RINGOVER_API_KEY=votre_cle_api_ringover
RINGOVER_API_URL=https://public-api.ringover.com/v2
RINGOVER_PHONE_NUMBER=+33XXXXXXXXX
RINGOVER_TRANSFER_NUMBER=+33XXXXXXXXX
RINGOVER_WEBHOOK_SECRET=

# --- OpenAI ---
OPENAI_API_KEY=sk-votre_cle_openai
OPENAI_MODEL=gpt-4o
OPENAI_TTS_VOICE=nova

# --- Agent IA ---
AI_AGENT_NAME=Sophie
AI_COMPANY_NAME=AssurancePro
AI_LANGUAGE=fr
AI_TEMPERATURE=0.7

# --- Leads ---
LEAD_SCORE_THRESHOLD=70
